#include "roBa.dtsi"

/* ==========================================================================
   1. キーマップ変形（トランスフォーム）の設定
   ========================================================================== */
&default_transform {
    col-offset = <6>;
};

/* ==========================================================================
   2. キースイッチ・マトリックス（KSCAN）の再定義（発熱対策）
   ==========================================================================   
   元のdtsi側で定義されていた row-gpios (D1, D2, D3) がトラックボールと衝突していたため、
   干渉しない完全に独立したピンへマトリックス全体のピンアサインを再マッピングします。
*/
&kscan0 {
    diode-direction = "col2row";
    
    /* 行（Row）の引っ越し先設定 */
    row-gpios
        = <&gpio0 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Xiao 0番ピン (D0) */
        , <&gpio0 3  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Xiao 1番ピン (D1) */
        , <&gpio0 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Xiao 2番ピン (D2) */
        , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Xiao 6番ピン (D6) */
        ;

    /* 列（Col）の設定 */
    col-gpios
        = <&xiao_d 10 GPIO_ACTIVE_HIGH>
        , <&xiao_d 9  GPIO_ACTIVE_HIGH>
        , <&xiao_d 8  GPIO_ACTIVE_HIGH>
        , <&xiao_d 7  GPIO_ACTIVE_HIGH>
        , <&gpio0 9   GPIO_ACTIVE_HIGH>  /* Xiao 5番ピン (D5) */
        ;
};

/* ==========================================================================
   3. トラックボール・インプットリスナーの設定
   ========================================================================== */
/ {
    trackball_listener {
        status = "okay";
        compatible = "zmk,input-listener";
        device = <&trackball>;
    };

    /* dtsi側でD5/D0を掴んでしまっていたエンコーダーを完全に無効化して解放 */
    /delete-node/ encoder_left;
    /delete-node/ encoder_right;
};

/* ==========================================================================
   4. トラックボール用 SPI通信（SPIM0）ピンアサイン定義
   ========================================================================== 
   キースイッチにD0〜D2を譲ったため、トラックボールの通信線は
   後半の D3, D4, 3.3V, GND 付近の安全なピンへアサインをまとめます。
*/
&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK,  0, 5)>,   /* Xiao 3番ピン (D3)  -> トラックボール SCK */
                    <NRF_PSEL(SPIM_MOSI, 0, 4)>;   /* Xiao 2番ピン (D2)  -> トラックボール MOSI */
        group2 {
            psels = <NRF_PSEL(SPIM_MISO, 0, 28)>;  /* Xiao 4番ピン (D4)  -> トラックボール MISO */
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK,  0, 5)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 4)>;
        group2 {
            psels = <NRF_PSEL(SPIM_MISO, 0, 28)>;
            low-power-enable;
        };
    };
};

&xiao_serial { status = "disabled"; };

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    
    /* CS（チップセレクト）ピンアサイン */
    cs-gpios = <&gpio0 29 GPIO_ACTIVE_LOW>;      /* Xiao 5番ピン (D5) -> トラックボール CS */

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        
        /* IRQ（割り込み信号ピン）アサイン */
        irq-gpios = <&gpio0 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; /* Xiao 1番ピン (D1) -> トラックボール IRQ */
    };
};
